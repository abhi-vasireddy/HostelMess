rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────
    // Helper Functions
    // ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.role == 'ADMIN';
    }

    function isCanteenStaff() {
      return isAuthenticated()
        && (request.auth.token.role == 'CANTEEN_STAFF'
         || request.auth.token.role == 'ADMIN');
    }

    function isOwner(userId) {
      return isAuthenticated()
        && request.auth.uid == userId;
    }

    function isAdminOrOwner(userId) {
      return isAdmin() || isOwner(userId);
    }

    // ──────────────────────────────────────────
    // Users Collection
    // ──────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own data; admins can read all
      allow read: if isAdminOrOwner(userId);

      // Users can update their own profile (but not role)
      // Admins can update any user
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId)
            && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'password', 'fcmTokens']));
      allow delete: if isAdmin();

      // Notification history subcollection
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ──────────────────────────────────────────
    // Daily Menus
    // ──────────────────────────────────────────
    match /dailyMenus/{day} {
      allow read: if true;  // Public read
      allow write: if isAdmin() || isCanteenStaff();
    }

    // ──────────────────────────────────────────
    // Feedback
    // ──────────────────────────────────────────
    match /feedbacks/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
      allow update: if false; // No edits once submitted
    }

    // ──────────────────────────────────────────
    // Announcements
    // ──────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if true;  // Public read
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Canteen
    // ──────────────────────────────────────────
    match /canteen/{itemId} {
      allow read: if true;
      allow write: if isAdmin() || isCanteenStaff();
    }

    // ──────────────────────────────────────────
    // Settings
    // ──────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Suggestions
    // ──────────────────────────────────────────
    match /suggestions/{suggestionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Todos
    // ──────────────────────────────────────────
    match /todos/{todoId} {
      allow read, write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Notes
    // ──────────────────────────────────────────
    match /notes/{noteId} {
      allow read, write, delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Hostel Complaints
    // ──────────────────────────────────────────
    match /hostel_complaints/{complaintId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status']);  // Admins can only update status
      allow delete: if false;  // Never delete complaints
    }

    // ──────────────────────────────────────────
    // Washing Machines
    // ──────────────────────────────────────────
    match /washing_machines/{machineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Laundry Bookings
    // ──────────────────────────────────────────
    match /laundry_bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin()
        || isOwner(get(/databases/$(database)/documents/laundry_bookings/$(bookingId)).data.userId);
      allow update: if false;
    }

    // ──────────────────────────────────────────
    // Hostel Categories
    // ──────────────────────────────────────────
    match /hostel_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Services
    // ──────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Sports Equipment
    // ──────────────────────────────────────────
    match /sports_equipment/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Sports Bookings
    // ──────────────────────────────────────────
    match /sports_bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin()
        || isOwner(get(/databases/$(database)/documents/sports_bookings/$(bookingId)).data.userId);
    }

    // ──────────────────────────────────────────
    // Team Requests
    // ──────────────────────────────────────────
    match /team_requests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Broadcasts (triggers Cloud Function)
    // ──────────────────────────────────────────
    match /broadcasts/{broadcastId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────
    // Deny everything else by default
    // ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
